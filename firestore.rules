rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helper functions
    // ---------------------------------------------------------------------
    function isAuth() {
      return request.auth != null;
    }

    function inviteEmail() {
      return isAuth() && request.auth.token.email is string
        ? lower(request.auth.token.email)
        : '';
    }

    function emailsMatch(storedEmail) {
      return isAuth()
        && request.auth.token.email is string
        && storedEmail is string
        && lower(storedEmail) == inviteEmail();
    }

    function userHasNoProject() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid))
        || !('projectId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projectId == null;
    }

    function getMemberData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data;
    }

    function isMember(projectId) {
      return isAuth()
        && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }

    function hasRole(projectId, roles) {
      return isMember(projectId) && getMemberData(projectId).role in roles;
    }

    function isOwner(projectId) {
      return isAuth()
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    // First Owner row: project.ownerId must match; only one self-member as Owner.
    function isFirstOwnerMemberCreate(projectId, memberId) {
      return isAuth()
        && request.auth.uid == memberId
        && request.resource.data.role == 'Owner'
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        && !exists(/databases/$(database)/documents/projects/$(projectId)/members/$(memberId));
    }

    function pendingInviteSnapshot(projectId, inviteId) {
      return get(/databases/$(database)/documents/projects/$(projectId)/invites/$(inviteId)).data;
    }

    function inviteAllowsJoin(projectId, inviteId) {
      let inv = pendingInviteSnapshot(projectId, inviteId);
      return inv.status == 'pending'
        && (
          ('openInvite' in inv && inv.openInvite == true)
          || (inv.email is string && lower(inv.email) == inviteEmail())
        );
    }

    // Invitee creates their member doc while a matching invite is still pending.
    function canCreateInvitedMember(projectId, memberId) {
      return isAuth()
        && request.auth.uid == memberId
        && request.resource.data.inviteId is string
        && exists(/databases/$(database)/documents/projects/$(projectId)/invites/$(request.resource.data.inviteId))
        && inviteAllowsJoin(projectId, request.resource.data.inviteId)
        && request.resource.data.role
          == get(/databases/$(database)/documents/projects/$(projectId)/invites/$(request.resource.data.inviteId)).data.role;
    }

    function workspaceRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasWorkspaceRole(roles) {
      return isAuth() && workspaceRole() in roles;
    }

    function userProjectId() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && 'projectId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projectId
        : null;
    }

    function isAssignedToProject(projectId) {
      return isAuth() && userProjectId() == projectId;
    }

    // ---------------------------------------------------------------------
    // Users collection (/users/{uid} is source of truth for project membership)
    // ---------------------------------------------------------------------
    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && request.auth.uid == uid;

      // Per-user subcollections (templates, testRuns, testRunResults, etc.) — legacy paths until fully project-scoped.
      match /{subPath=**} {
        allow read, write: if isAuth() && request.auth.uid == uid;
      }
    }

    // ---------------------------------------------------------------------
    // Projects / workspace
    // ---------------------------------------------------------------------
    match /projects/{projectId} {
      // get (single doc): members OR the project owner can read.
      // This lets isFirstOwnerMemberCreate verify ownerId before the member doc exists.
      allow get: if isMember(projectId)
        || (isAuth() && resource.data.ownerId == request.auth.uid);
      // list (collection queries): any signed-in user can query.
      // Required so new users can check slug availability during onboarding.
      allow list: if isAuth();
      allow create: if isAuth()
        && request.resource.data.ownerId == request.auth.uid
        && userHasNoProject();
      allow update: if hasRole(projectId, ['Owner', 'Admin']);
      allow delete: if isOwner(projectId);

      match /members/{memberId} {
        allow read: if isMember(projectId);
        allow create: if isFirstOwnerMemberCreate(projectId, memberId)
          || canCreateInvitedMember(projectId, memberId);
        allow update, delete: if hasRole(projectId, ['Owner', 'Admin']);
      }

      match /invites/{inviteId} {
        allow read: if isMember(projectId)
          || (resource.data.email is string && emailsMatch(resource.data.email))
          || ('openInvite' in resource.data && resource.data.openInvite == true && isAuth());
        allow create: if hasRole(projectId, ['Owner', 'Admin']);
        allow update: if hasRole(projectId, ['Owner', 'Admin'])
          || (resource.data.email is string && emailsMatch(resource.data.email))
          || ('openInvite' in resource.data && resource.data.openInvite == true && isAuth());
        allow delete: if hasRole(projectId, ['Owner', 'Admin']);
      }

      match /testCases/{docId} {
        allow read: if isMember(projectId) || isOwner(projectId) || isAssignedToProject(projectId);
        allow write: if hasRole(projectId, ['Owner', 'Admin', 'QA Lead', 'Member'])
          || (isOwner(projectId) && isAssignedToProject(projectId));
      }

      match /testRuns/{docId} {
        allow read: if isMember(projectId);
        allow write: if hasRole(projectId, ['Owner', 'Admin', 'QA Lead', 'Member']);
      }

      match /testRunResults/{docId} {
        allow read: if isMember(projectId);
        allow write: if hasRole(projectId, ['Owner', 'Admin', 'QA Lead', 'Member']);
      }

      match /bugs/{bugId} {
        allow read: if isMember(projectId);
        allow write: if hasRole(projectId, ['Owner', 'Admin', 'QA Lead', 'Member']);

        match /comments/{commentId} {
          allow read: if isMember(projectId);
          allow write: if hasRole(projectId, ['Owner', 'Admin', 'QA Lead', 'Member']);
        }
      }

      match /notificationSettings/{docId} {
        allow read: if isMember(projectId);
        allow write: if hasRole(projectId, ['Owner', 'Admin']);
      }

      match /aiGenerationLogs/{docId} {
        allow read: if isMember(projectId);
        allow write: if isMember(projectId);
      }

      match /aiPromptTemplates/{docId} {
        allow read: if isMember(projectId);
        allow write: if hasRole(projectId, ['Owner', 'Admin', 'QA Lead']);
      }

      match /meta/{metaId} {
        allow read: if isMember(projectId);
        allow write: if hasRole(projectId, ['Owner', 'Admin', 'QA Lead', 'Member']);
      }

      match /integrations/{integrationId} {
        allow read: if isMember(projectId);
        allow write: if hasRole(projectId, ['Owner', 'Admin']);
      }
    }

    // ---------------------------------------------------------------------
    // Legacy top-level workspace collections (still used until client migrates paths)
    // ---------------------------------------------------------------------
    match /testCases/{docId} {
      allow read: if hasWorkspaceRole(['Owner', 'Admin', 'QA Lead', 'Member', 'Viewer']);
      allow create, update: if hasWorkspaceRole(['Owner', 'Admin', 'QA Lead', 'Member']);
      allow delete: if hasWorkspaceRole(['Owner', 'Admin', 'QA Lead']);
    }

    match /activityLogs/{docId} {
      allow read: if hasWorkspaceRole(['Owner', 'Admin', 'QA Lead', 'Member', 'Viewer']);
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /comments/{docId} {
      allow read: if hasWorkspaceRole(['Owner', 'Admin', 'QA Lead', 'Member', 'Viewer']);
      allow create, update, delete: if hasWorkspaceRole(['Owner', 'Admin', 'QA Lead', 'Member']);
    }
  }
}
