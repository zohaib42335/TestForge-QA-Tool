# Copy to .env and fill in values. Restart `npm run dev` after changes.

# --- Google Sheets (existing) ---
VITE_GOOGLE_SHEETS_API_KEY=
VITE_GOOGLE_SHEET_ID=
VITE_GOOGLE_CLIENT_ID=

# Optional. OAuth redirect URI — must match Google Cloud Console → Credentials → OAuth 2.0 Client
# → "Authorized redirect URIs" EXACTLY (including trailing slash and http vs https).
# Leave empty for local/dev: the app uses <your-current-origin>/ automatically
# (e.g. http://localhost:5173/).
# For Firebase Hosting production, set e.g. https://YOUR_PROJECT.web.app/
# Add every URL you use to the Console: localhost, 127.0.0.1, and production.
VITE_GOOGLE_OAUTH_REDIRECT_URI=

# --- Firebase Web App (Step 1 — Authentication) ---
# Firebase Console → Project settings → Your apps → Web app → SDK snippet (config).
# Use plain KEY=value lines only — do not paste the JavaScript firebaseConfig object here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to true only when running `firebase emulators:start --only functions` (port 5001).
# Leave unset/false in normal dev so callables hit deployed Cloud Functions.
# VITE_USE_FUNCTIONS_EMULATOR=true
