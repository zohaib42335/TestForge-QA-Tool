rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Workspace logo: only project members may write; public read for displaying in app.
    match /projects/{projectId}/logo/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.exists(/databases/(default)/documents/projects/$(projectId)/members/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role in ['Owner', 'Admin'];
    }
  }
}
